generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String      @id @default(cuid())
  email     String      @unique
  password  String
  name      String?
  createdAt DateTime    @default(now())
  plate     PlateItem[]
}

model PlateItem {
  id         String   @id @default(cuid())
  user       User     @relation(fields: [userId], references: [id])
  userId     String
  externalId String?
  name       String
  calories   Float?
  protein    Float?
  createdAt  DateTime @default(now())
}
